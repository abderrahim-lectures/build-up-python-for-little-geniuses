---
title: Home
layout: base.njk
---
<div class="hero">
  <div class="hero-art-wrap">
    <img class="hero-art" src="/images/cover.png" alt="Build Up: Python for Little Geniuses. A blocky pixel-art robot mascot stands on clouds holding a flag, under a starry blue sky.">
  </div>

  <h1>Build Up: Python for Little Geniuses</h1>
  <p class="brief">A Python book for 11-year-olds, taught through math. Learn
  to code one chapter at a time, and build your own simplified,
  Minecraft-inspired game along the way.</p>
  <p><a class="start-link" href="/chapter0/">Start reading &rarr; Chapter 0</a></p>
</div>

<h2 id="chapters">All chapters</h2>
<div class="chapter-preview-grid">
  {% set chapters = [
    {num: 0, title: "Welcome", theme: "ch00"},
    {num: 1, title: "Variables", theme: "crates"},
    {num: 2, title: "Arithmetic", theme: "ch02"},
    {num: 3, title: "Strings &amp; Words", theme: "ch03"},
    {num: 4, title: "Making Choices", theme: "ch04"},
    {num: 5, title: "Lists", theme: "inventory"},
    {num: 6, title: "Repeat With For", theme: "ch06"},
    {num: 7, title: "Repeat Until", theme: "ch07"},
    {num: 8, title: "Functions", theme: "ch08"},
    {num: 9, title: "Area &amp; Perimeter", theme: "fence"},
    {num: 10, title: "The Grid", theme: "ch10"},
    {num: 11, title: "Dictionaries", theme: "shop"},
    {num: 12, title: "Chance", theme: "ch12"},
    {num: 13, title: "Blueprints", theme: "classes"},
    {num: 14, title: "Debugging", theme: "ch14"},
    {num: 15, title: "Capstone", theme: "capstone"}
  ] %}
  {% for ch in chapters %}
  <a class="chapter-preview" href="/chapter{{ ch.num }}/">
    <div class="chapter-preview-media">
      <div class="num-badge">{{ "0" if ch.num < 10 else "" }}{{ ch.num }}</div>
      <div class="chapter-preview-sky"></div>
      <div class="chapter-preview-tiles {{ ch.theme }}"></div>
    </div>
    <div class="caption">Ch.{{ ch.num }} &middot; {{ ch.title | safe }}</div>
  </a>
  {% endfor %}
</div>

<script>
(function () {
  var wrap = document.querySelector('.hero-art-wrap');
  var art = wrap && wrap.querySelector('.hero-art');
  if (!wrap || !art || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  wrap.addEventListener('mousemove', function (e) {
    var rect = wrap.getBoundingClientRect();
    var dx = (e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
    var dy = (e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2);
    dx = Math.max(-1, Math.min(1, dx));
    dy = Math.max(-1, Math.min(1, dy));
    art.style.transform = 'rotateY(' + (dx * 10) + 'deg) rotateX(' + (dy * -10) + 'deg) translateZ(10px)';
  });
  wrap.addEventListener('mouseleave', function () {
    art.style.transform = 'rotateY(0deg) rotateX(0deg) translateZ(0px)';
  });
})();
</script>
